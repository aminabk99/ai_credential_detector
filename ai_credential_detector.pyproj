<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>fd0d14de-99bd-45e6-bf2c-8c48efeeebb4</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>src\main.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>ai_credential_detector</Name>
    <RootNamespace>ai_credential_detector</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="ai_credential_detector.py" />
    <Compile Include="src\auth_simulator.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\feature_extractor.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\main.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\ml_detector.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\train_model.py">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="data\" />
    <Folder Include="models\" />
    <Folder Include="logs\" />
    <Folder Include="root\" />
    <Folder Include="src\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="data\login_events.csv" />
    <Content Include="logs\alerts.log" />
    <Content Include="models\credential_model.pkl" />
    <Content Include="root\README.md" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
